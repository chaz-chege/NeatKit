# Cloudflare Pages — _headers
# These run on the free plan with zero config needed

/*
  X-Frame-Options: SAMEORIGIN
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  X-XSS-Protection: 1; mode=block

# Cache JS/CSS assets aggressively (1 year) since they're content-hashed
/assets/*
  Cache-Control: public, max-age=31536000, immutable

# vendor/ffmpeg — worker.js and const.js
# cross-origin so COEP pages can load them even when requested by cross-origin scripts
/vendor/ffmpeg/*
  Cache-Control: public, max-age=31536000, immutable
  Cross-Origin-Resource-Policy: cross-origin

# Service worker — never cache so updates propagate immediately
/sw.js
  Cache-Control: no-cache

# Cache images
/*.png
  Cache-Control: public, max-age=604800
/*.jpg
  Cache-Control: public, max-age=604800
/*.webp
  Cache-Control: public, max-age=604800
/*.svg
  Cache-Control: public, max-age=604800

# HTML — short cache so updates propagate fast
/*.html
  Cache-Control: public, max-age=3600, stale-while-revalidate=86400

# Sitemap
/sitemap.xml
  Cache-Control: public, max-age=86400
  Content-Type: application/xml

# robots.txt
/robots.txt
  Cache-Control: public, max-age=86400

# ── CAMERA TOOLS ─────────────────────────────────────────────────────
/tools/qr-scanner.html
  Permissions-Policy: camera=(self)

/tools/photo-to-pdf.html
  Permissions-Policy: camera=(self)

# Video tools — both .html and extensionless URLs
/tools/video-trim.html
  Permissions-Policy: camera=()
  Cross-Origin-Opener-Policy: same-origin
  Cross-Origin-Embedder-Policy: require-corp

/tools/video-trim
